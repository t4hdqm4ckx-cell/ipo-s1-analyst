# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Max tokens per analysis response (default: 8096)
MAX_TOKENS=8096

# Cache S-1 documents locally to avoid re-downloading (default: true)
EDGAR_CACHE=true

# Output directory for reports (default: ./reports)
REPORTS_DIR=./reports

# Verbose logging (default: false)
VERBOSE=false
